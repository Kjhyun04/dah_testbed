# DAH 테스트베드 환경 변수 (.env 로 복사해 사용)

# ArduPilot 빌드 태그 (UAV=Copter-4.5). UGV로 바꾸려면 Rover-4.5 + air/Dockerfile의 ./waf rover
ARDUPILOT_TAG=Copter-4.5

# Gazebo(공중 air 컨테이너) — P-15/P-23/P-25
GZ_HEADLESS=0                         # 1이면 GUI/VNC 생략(서버만, :6080 미사용)
HOME_LOC=37.5665,126.9780,30,0        # SITL 시작 위치 lat,lon,alt,yaw
CAM_HOST=host.docker.internal         # Gazebo 카메라 RTP 수신 측(지상/호스트)
CAM_PORT=5600

# 주소체계 (docs/address-scheme.md 와 일치 유지)
AV_SYSID=1            # 기체(autopilot)
GCS_SYSID=255         # QGroundControl
VSM_SYSID=255         # 지상 VSM(서명 종단점)
VSM_COMPID=195

# MAVLink v2 서명 공유 비밀 (실사용 시 반드시 변경)
SIGNING_PASSPHRASE=dah-m0-shared-secret-change-me
