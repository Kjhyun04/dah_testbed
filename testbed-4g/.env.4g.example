# testbed-4g 환경값 — EC2에서 docker_open5gs(EPC) 기동 후 실제 값으로 채워 .env.4g 로 복사
#   docker network ls                  → EPC_NET (docker_open5gs 네트워크)
#   docker inspect <mme 컨테이너>       → MME_IP
#   기존 testbed dahnet 네트워크 이름    → DAHNET
#   EPC_NET 서브넷의 빈 IP              → ENB_IP

# ★검증(2026-07-01) 기준 기본값. 10-epc-up.sh 가 실측으로 덮어씀.
EPC_NET=docker_open5gs_default      # docker_open5gs 기본 네트워크(확인됨)
DAHNET=testbed_dahnet               # 기존 testbed 의 dahnet (GPS off-셀룰러)
MME_IP=172.22.0.9                   # MME 컨테이너 IP (.env 기지값)
ENB_IP=172.22.0.22                  # SRS_ENB_IP (.env 기지값)
SRSRAN_IMAGE=docker_srslte          # docker_open5gs 가 빌드하는 srsRAN(ZMQ) 이미지
ZMQ_PEER=srsenb_zmq                 # 단일UE=srsenb_zmq / 멀티UE=gr-broker(B①)

# ── G0(LTE attach) 후 확인해 채움 (bridge.4g.yml 용) ──
UAV_UE_IP=10.45.0.2                 # uav-ue tun_srsue IP
GCS_UE_IP=10.45.0.3                 # gcs-ue tun_srsue IP
AIR_IMAGE=dah-air                   # 기존 testbed air 이미지 태그
TOOLS_IMAGE=dah-tools
